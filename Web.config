  <system.webServer>
    <handlers>
      <remove name="ExtensionlessUrlHandler-Integrated-4.0" />
      <remove name="OPTIONSVerbHandler" />
      <add name="OPTIONSVerbHandler" path="*" verb="OPTIONS" modules="ProtocolSupportModule" requireAccess="None" responseBufferLimit="4194304" />
      <remove name="TRACEVerbHandler" />
      <add name="ExtensionlessUrlHandler-Integrated-4.0" path="*." verb="*" type="System.Web.Handlers.TransferRequestHandler" preCondition="integratedMode,runtimeVersionv4.0" />
    </handlers>
    <httpProtocol>
      <customHeaders>
        <add name="Access-Control-Allow-Origin" value="*" />
        <add name="Access-Control-Allow-Headers" value="Content-Type" />
        <add name="Access-Control-Allow-Methods" value="GET, POST, PUT, DELETE, OPTIONS" />
        <add name="Access-Control-Allow-Credentials" value="true" />
      </customHeaders>
    </httpProtocol>
    <defaultDocument>
      <files>
        <add value="Default.html" />
      </files>
    </defaultDocument>
 <security>
            <requestFiltering>
                <requestLimits maxAllowedContentLength="300000000" maxUrl="40960" maxQueryString="204800" />
            </requestFiltering>
        </security>
  </system.webServer>
  <appSettings>
    <!--
        Application have SMS Gateway Options, Which gateway do you want to select?
        1 for Hypermedia SMS gateway
        2 for Dinstar SMS gateway
    -->
    <add key="SelectedGateway" value="2" />
    <add key="CanReceiveSMS" value="1" />
    <!--0 For No and 1 For Yes-->
    <!--Hypermedia SMS Gateway settings Start-->
    <add key="HM_ServerIPAddress" value="networks8.servebbs.net" />
    <add key="HM_Port" value="63333" />
    <add key="HM_Password" value="admin" />
    <!--Hypermedia SMS Gateway settings END-->
    <!--Dinstar SMS Gateway settings Start-->
    <add key="DS_ServerBaseURL" value="http://81.130.136.62:54541" />
    <add key="DS_UserName" value="admin" />
    <add key="DS_Password" value="Cabtds123" />
    <!--Ports should be enter with comma seperated, for example: 0,1,2-->
    <add key="DS_SendingMsgPort" value="0" />
    <add key="DS_ReceivingMsgPort" value="0" />
    <!--Dinstar SMS Gateway settings END-->
	  <add key="ConnectionString" value="aEJpkEUQcq3LFekmGYSS1gR69mzttic3mA0k31Ni5q4wijoqG5Z4cWwuD9kHqMAD+KL3e2sgojS2ZELKQVZAs1TpVTdnYTmVFf/2IA1kUKqw0e9xQjgb2zil9Dc4qA1DJgEJMB8+QQEDSd42h8xqBAvxl00Nvr32" />
